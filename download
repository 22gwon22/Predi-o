function excecoesInterjornada(txt, mapa) {
  const out = new Map();
  parseCSV(txt).forEach((r) => {
    const n = get(r, ["MOTORISTA", "NOME", "APELIDO"]);
    const motivo = get(r, ["MOTIVO", "OBSERVACAO"]) || "Desconsiderado";
