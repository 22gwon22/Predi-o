      if (ignorar.has(ma.norm)) {
        interjornadas.push({ motorista: ma.nome, status: "Desconsiderado", descanso: null, deficit: 0, hoje: ignorar.get(ma.norm), amanha: `${r.rota} • ${ma.papel}` });
